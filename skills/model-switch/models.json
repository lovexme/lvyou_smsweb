{
  "version": 2,
  "defaultModel": "default",
  "aliases": {
    "默认": "default",
    "default": "default",
    "4o": "gpt-4o",
    "gpt4o": "gpt-4o",
    "4.1": "gpt-4.1",
    "gpt4.1": "gpt-4.1",
    "o3": "o3",
    "o4-mini": "o4-mini",
    "gemini flash": "gemini-2.0-flash",
    "写作模型": "gpt-4.1",
    "编码模型": "o3",
    "推理模型": "o3",
    "高质量模型": "gpt-4.1",
    "省钱模型": "o4-mini",
    "便宜模型": "o4-mini",
    "快模型": "gemini-2.0-flash"
  },
  "presets": {
    "writing": {
      "label": "写作模型",
      "model": "gpt-4.1",
      "useFor": ["写作", "润色", "总结", "长文输出"]
    },
    "coding": {
      "label": "编码模型",
      "model": "o3",
      "useFor": ["编程", "调试", "脚本", "工程问题"]
    },
    "reasoning": {
      "label": "推理模型",
      "model": "o3",
      "useFor": ["复杂分析", "多步推理", "方案设计"]
    },
    "quality": {
      "label": "高质量模型",
      "model": "gpt-4.1",
      "useFor": ["高质量回答", "正式输出", "精修内容"]
    },
    "budget": {
      "label": "省钱模型",
      "model": "o4-mini",
      "useFor": ["低成本", "日常问答", "轻量任务"]
    },
    "fast": {
      "label": "快模型",
      "model": "gemini-2.0-flash",
      "useFor": ["快速响应", "速查", "草稿"]
    }
  },
  "notes": {
    "gemini pro": "Keep as-is unless your environment has a known exact configured id.",
    "claude sonnet": "Keep as-is unless your environment has a known exact configured id."
  }
}
